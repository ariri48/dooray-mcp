# Dooray API 인증 토큰 (필수)
# 형식: {org_id}:{token}
# Dooray > 설정 > API 토큰에서 발급
DOORAY_API_TOKEN=your_org_id:your_token_here

# 테넌트 ID (필수) - dooray:// 링크 생성에 사용
DOORAY_TENANT_ID=1387695619080878080

# 기본 프로젝트 ID (선택) - project_id 미지정 시 사용
DOORAY_DEFAULT_PROJECT_ID=

# Dooray Messenger Webhook URL (선택) - send_webhook 기능용
DOORAY_WEBHOOK_URL=

# 개인 프로젝트 ID (각 팀원별 설정)
# "내프로젝트", "개인", "my" 등으로 접근 가능
DOORAY_MY_PROJECT_ID=

# 자동 업데이트 (선택) - 서버 시작 시 git pull로 최신 코드 반영 (기본: 켜짐)
# 끄려면 false로 설정
DOORAY_MCP_AUTO_UPDATE=
